@using Microsoft.AspNetCore.Identity
@inject SignInManager<LMS.Models.ApplicationUser> SignInManager
@inject UserManager<LMS.Models.ApplicationUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
    var isAdmin = User.IsInRole("Admin");
    var isInstructor = User.IsInRole("Instructor");
    var isStudent = User.IsInRole("Student");
}

<aside class="w-64 bg-white min-h-screen flex flex-col shadow-sm">

    <!-- Logo -->
    <div class="px-6 py-5 border-b border-gray-100">
        <span class="text-xl font-bold text-orange-500">📚 EduLMS</span>
    </div>

    <!-- User Info -->
    <div class="px-6 py-4 border-b border-gray-100">
        <p class="text-sm font-semibold text-gray-800">@user?.FullName</p>
        <p class="text-xs text-gray-400">@user?.Email</p>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-4 py-4 space-y-1">

        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-2 mb-2">Main Menu</p>

        <a asp-controller="Dashboard" asp-action="Index"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
            🏠 Dashboard
        </a>

        <a asp-controller="Course" asp-action="Index"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
            📖 Courses
        </a>

        @if (isStudent)
        {
            <a asp-controller="Assignment" asp-action="Index" asp-route-courseId="0"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                📝 Assignments
            </a>

            <a asp-controller="Progress" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                📈 My Progress
            </a>

            <a asp-controller="Grade" asp-action="MyGrades"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                📊 My Grades
            </a>

            <a asp-controller="Grade" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                📊 Grades
            </a>
        }

        @if (isInstructor || isAdmin)
        {
            <a asp-controller="Assignment" asp-action="Index" asp-route-courseId="0"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                📝 Assignments
            </a>

            <a asp-controller="Quiz" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                🧠 Quizzes
            </a>

            <a asp-controller="Grade" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                📊 Grades
            </a>

            <a asp-controller="Grade" asp-action="Book" asp-route-courseId="0"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                📊 Grade Book
            </a>

            <a asp-controller="Enrollment" asp-action="Requests"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                📋 Enrollment Requests
            </a>
        }

        @if (isAdmin)
        {
            <div class="pt-3">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-2 mb-2">Admin</p>
                <a asp-controller="Admin" asp-action="Index"
                       class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-500 transition">
                    ⚙️ Admin Panel
                </a>
            </div>
        }

    </nav>

    <!-- Bottom -->
    <div class="px-4 py-4 border-t border-gray-100 space-y-1">
        <a asp-controller="Account" asp-action="Login"
               class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-gray-50 transition">
            ⚙️ Settings
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit"
                    class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-red-500 hover:bg-red-50 transition">
                🚪 Logout
            </button>
        </form>
    </div>

</aside>