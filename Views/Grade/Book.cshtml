@{
    ViewData["Title"] = "Grade Book";
    var course = ViewBag.Course as LMS.Models.Course;
    var submissions = ViewBag.Submissions as List<LMS.Models.AssignmentSubmission>;
    var attempts = ViewBag.QuizAttempts as List<LMS.Models.QuizAttempt>;
}

<div class="max-w-5xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-xl font-bold text-gray-800">Grade Book</h2>
            <p class="text-sm text-gray-400">@course?.Title</p>
        </div>
    </div>

    <!-- Assignment Submissions -->
    <div class="bg-white rounded-2xl shadow-sm p-6">
        <h3 class="font-semibold text-gray-700 mb-4">Assignment Submissions</h3>

        @if (submissions == null || !submissions.Any())
        {
            <p class="text-gray-400 text-sm">No submissions yet.</p>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var sub in submissions)
                {
                    <div class="border border-gray-100 rounded-xl p-4">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-sm font-medium text-gray-800">@sub.Student?.FullName</p>
                                <p class="text-xs text-gray-400">@sub.Assignment?.Title</p>
                                <a href="@sub.FilePath" target="_blank"
                                   class="text-xs text-orange-500 hover:underline">@sub.OriginalFileName</a>
                            </div>
                            <div class="text-right shrink-0">
                                @if (sub.Grade.HasValue)
                                {
                                    <span class="text-green-600 font-semibold text-sm">@sub.Grade / @sub.Assignment?.MaxScore</span>
                                    <p class="text-xs text-gray-400">@sub.Feedback</p>
                                }
                                else
                                {
                                    <span class="text-yellow-500 text-xs">Not graded</span>
                                }
                            </div>
                        </div>

                        <!-- Grade form -->
                        <form asp-controller="Grade" asp-action="GradeSubmission" method="post"
                              class="mt-3 flex items-center gap-3 flex-wrap">
                            <input type="hidden" name="SubmissionId" value="@sub.Id" />
                            <input type="number" name="Score" min="0" max="@sub.Assignment?.MaxScore" step="0.5"
                                   value="@(sub.Grade?.ToString() ?? "")"
                                   placeholder="Score /@sub.Assignment?.MaxScore"
                                   class="w-28 border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
                            <input type="text" name="Feedback"
                                   value="@(sub.Feedback ?? "")"
                                   placeholder="Feedback (optional)"
                                   class="flex-1 border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
                            <button type="submit"
                                    class="bg-orange-500 hover:bg-orange-600 text-white text-sm px-4 py-1.5 rounded-lg transition">
                                Save
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Quiz Attempts -->
    <div class="bg-white rounded-2xl shadow-sm p-6">
        <h3 class="font-semibold text-gray-700 mb-4">Quiz Attempts (Auto-graded)</h3>

        @if (attempts == null || !attempts.Any())
        {
            <p class="text-gray-400 text-sm">No quiz attempts yet.</p>
        }
        else
        {
            <div class="space-y-2">
                @foreach (var a in attempts.OrderByDescending(a => a.Score))
                {
                    var percent = a.Score / Math.Max(1, a.Quiz?.TotalMarks ?? 100) * 100;
                    <div class="flex items-center justify-between border border-gray-100 rounded-xl p-4">
                        <div>
                            <p class="text-sm font-medium text-gray-700">@a.Student?.FullName</p>
                            <p class="text-xs text-gray-400">@a.Quiz?.Title · @a.SubmittedAt?.ToString("MMM dd, yyyy")</p>
                        </div>
                        <span class="font-bold text-lg @(percent >= 50 ? "text-green-500" : "text-red-400")">
                            @a.Score.ToString("0.##")/@a.Quiz?.TotalMarks
                        </span>
                    </div>
                }
            </div>
        }
    </div>
</div>
