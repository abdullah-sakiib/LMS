@model LMS.ViewModels.QuizWorkspaceVM
@{
    ViewData["Title"] = "Quizzes";
    ViewData["PageTitle"] = "Quizzes";
    ViewData["PageSubtitle"] = Model.IsStudent ? "Test your knowledge" : "Manage quizzes and review attempts";
}
<style>
  .btn-primary { background:linear-gradient(135deg,#4f46e5,#6366f1); box-shadow:0 4px 14px rgba(99,102,241,.3); transition:all .25s; }
  .btn-primary:hover { transform:translateY(-1px); }
  .quiz-list-card { transition:transform .2s ease,box-shadow .2s ease; }
  .quiz-list-card:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(0,0,0,.06); }
</style>
<div class="max-w-7xl mx-auto">
  @if (!Model.IsStudent)
  {
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 mb-6">
      <div class="mb-4"><h3 class="font-semibold text-slate-800 text-sm">Create Quiz</h3><p class="text-xs text-slate-400 mt-0.5">Create a quiz for one of your courses, then add questions.</p></div>
      @if (Model.InstructorCourses.Any())
      {
        <form asp-action="CreateQuick" method="post" class="grid md:grid-cols-4 gap-3">
          <input name="title" type="text" placeholder="Quiz title" required class="md:col-span-2 border border-slate-200 rounded-xl px-3 py-2.5 text-sm" />
          <select name="courseId" required class="border border-slate-200 rounded-xl px-3 py-2.5 text-sm"><option value="">Select course</option>@foreach (var course in Model.InstructorCourses) { <option value="@course.Id">@course.Title</option> }</select>
          <button class="btn-primary text-white font-semibold rounded-xl px-4 py-2.5 text-sm"><i class="ri-add-circle-line"></i> Create</button>
          <div><label class="block text-xs font-semibold text-slate-500 mb-1">Total marks</label><input name="totalMarks" type="number" min="1" value="100" class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm"/></div>
          <div><label class="block text-xs font-semibold text-slate-500 mb-1">Time limit (minutes)</label><input name="timerMinutes" type="number" min="1" value="30" class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm"/></div>
        </form>
      }
      else { <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">No published course found for your account. Create a course first, then add quizzes.</div> }
    </div>
  }
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4"><div class="w-9 h-9 bg-primary-50 rounded-xl flex items-center justify-center mb-2"><i class="ri-questionnaire-line text-primary-500"></i></div><p class="text-2xl font-bold text-slate-800">@Model.Total</p><p class="text-xs text-slate-400">Total quizzes</p></div>
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4"><div class="w-9 h-9 bg-emerald-50 rounded-xl flex items-center justify-center mb-2"><i class="ri-checkbox-circle-line text-emerald-500"></i></div><p class="text-2xl font-bold text-slate-800">@Model.Completed</p><p class="text-xs text-slate-400">@(Model.IsStudent ? "Completed" : "Students attempted")</p></div>
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4"><div class="w-9 h-9 bg-amber-50 rounded-xl flex items-center justify-center mb-2"><i class="ri-time-line text-amber-500"></i></div><p class="text-2xl font-bold text-slate-800">@Model.Pending</p><p class="text-xs text-slate-400">@(Model.IsStudent ? "Pending" : "Students not attempted")</p></div>
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4"><div class="w-9 h-9 bg-violet-50 rounded-xl flex items-center justify-center mb-2"><i class="ri-star-line text-violet-500"></i></div><p class="text-2xl font-bold text-slate-800">@Model.AveragePercent.ToString("0")%</p><p class="text-xs text-slate-400">Average score</p></div>
  </div>
  @if (!Model.IsStudent)
  {
    <div class="grid sm:grid-cols-3 gap-4 mb-6"><div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4"><p class="text-xs text-slate-500">Total Attempts Submitted</p><p class="text-xl font-bold text-slate-800 mt-1">@Model.TotalAttempts</p></div><div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4"><p class="text-xs text-slate-500">Students In Your Quiz Courses</p><p class="text-xl font-bold text-slate-800 mt-1">@Model.TotalStudents</p></div><div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4"><p class="text-xs text-slate-500">Overall Participation</p><p class="text-xl font-bold text-emerald-600 mt-1">@Model.ParticipationPercent.ToString("0")%</p></div></div>
  }
  <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-4">
    @foreach (var card in Model.Cards)
    {
      var completed = card.MyAttempt?.SubmittedAt != null;
      var percent = completed ? card.MyAttempt!.Score / Math.Max(1, card.Quiz.TotalMarks) * 100 : 0;
      <article class="quiz-list-card bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="h-2 @(Model.IsStudent && completed ? "bg-emerald-400" : Model.IsStudent ? "bg-amber-400" : "bg-indigo-400")"></div>
        <div class="p-5">
          <div class="flex items-start justify-between mb-3"><div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center"><i class="ri-questionnaire-line text-indigo-600"></i></div><span class="text-xs font-semibold @(Model.IsStudent && completed ? "text-emerald-600 bg-emerald-50" : Model.IsStudent ? "text-amber-500 bg-amber-50" : "text-indigo-600 bg-indigo-50") border border-slate-100 px-2 py-0.5 rounded-full">@(Model.IsStudent ? completed ? "Completed" : "Pending" : "Manage")</span></div>
          <h3 class="font-semibold text-slate-800 text-sm mb-1">@card.Quiz.Title</h3>
          <p class="text-xs text-slate-400 mb-3">@card.Quiz.Course?.Title &middot; @card.QuestionCount questions &middot; @card.Quiz.TimerMinutes min</p>
          @if (Model.IsStudent && completed)
          {
            <div class="flex items-center gap-2 mb-3"><div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden"><div class="h-full bg-emerald-400 rounded-full" style="width:@percent.ToString("0")%"></div></div><span class="text-sm font-bold text-emerald-600">@card.MyAttempt!.Score.ToString("0.##")/@card.Quiz.TotalMarks</span></div>
            <a asp-action="Take" asp-route-id="@card.Quiz.Id" class="w-full text-sm font-medium text-primary-600 border border-primary-200 hover:bg-primary-50 py-2.5 rounded-xl inline-flex justify-center">Review answers</a>
          }
          else if (Model.IsStudent)
          {
            <div class="flex items-center justify-between text-xs text-slate-500 mb-4"><span><i class="ri-timer-line"></i> @card.Quiz.TimerMinutes min timer</span><span>@card.Quiz.TotalMarks pts</span></div>
            <a asp-action="Take" asp-route-id="@card.Quiz.Id" class="btn-primary w-full text-white font-semibold py-2.5 rounded-xl text-sm flex items-center justify-center gap-2"><i class="ri-play-circle-line"></i> Start Quiz</a>
          }
          else
          {
            <div class="flex items-center justify-between text-xs text-slate-500 mb-3"><span><i class="ri-user-follow-line"></i> @card.AttemptCount/@card.EligibleStudents students</span><span>@card.ParticipationPercent.ToString("0")% participation</span></div>
            <div class="flex items-center justify-between text-xs text-slate-500 mb-4"><span>Avg score</span><strong class="text-slate-700">@card.AverageScorePercent.ToString("0")%</strong></div>
            <details class="mb-3 rounded-xl border border-slate-100"><summary class="cursor-pointer px-3 py-2 text-xs font-semibold text-slate-700">Student Breakdown</summary><div class="border-t px-3 py-3 grid grid-cols-2 gap-3 text-xs"><div><p class="text-emerald-600 font-semibold mb-1">Attempted</p>@foreach (var student in card.AttemptedStudents) { <p>@student.FullName</p> }</div><div><p class="text-amber-600 font-semibold mb-1">Not Attempted</p>@foreach (var student in card.NotAttemptedStudents) { <p>@student.FullName</p> }</div></div></details>
            <div class="grid grid-cols-2 gap-2"><a asp-action="Edit" asp-route-id="@card.Quiz.Id" class="text-center text-sm font-medium text-primary-600 border border-primary-200 py-2.5 rounded-xl">Edit Quiz</a><a asp-action="Results" asp-route-id="@card.Quiz.Id" class="text-center text-sm font-medium text-indigo-600 border border-indigo-200 py-2.5 rounded-xl">Evaluate</a></div>
          }
        </div>
      </article>
    }
    @if (!Model.Cards.Any()) { <div class="sm:col-span-2 xl:col-span-3 bg-white rounded-2xl border border-slate-100 shadow-sm p-8 text-center"><p class="text-slate-700 font-semibold">No quizzes available yet</p><p class="text-sm text-slate-400 mt-1">@(Model.IsStudent ? "Enroll in a course and ask your instructor to publish quizzes." : "Create your first quiz using the form above.")</p></div> }
  </div>
</div>
