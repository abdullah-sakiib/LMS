@model LMS.ViewModels.QuizVM
@{
    ViewData["Title"] = "Create Quiz";
}

<div class="max-w-3xl mx-auto">
    @Html.AntiForgeryToken()
    <div class="bg-white rounded-2xl shadow-sm p-6 mb-5">
        <h2 class="text-xl font-bold text-gray-800 mb-4">New Quiz</h2>
        <div class="space-y-4">
            <div>
                <label class="text-sm font-medium text-gray-700">Total Marks</label>
                <input id="quizMarks" type="number" value="@Model.TotalMarks" min="1"
                       class="mt-1 w-32 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            </div>
            <div>
                <label class="text-sm font-medium text-gray-700">Quiz Title</label>
                <input id="quizTitle" type="text" placeholder="e.g. Chapter 1 Quiz"
                       class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
            <div>
                <label class="text-sm font-medium text-gray-700">Timer (minutes)</label>
                <input id="quizTimer" type="number" value="10" min="1"
                       class="mt-1 w-32 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
        </div>
    </div>

    <!-- Questions -->
    <div id="questionsContainer" class="space-y-4"></div>

    <div class="flex gap-3 mt-5">
        <button onclick="addQuestion('MCQ')"
                class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm px-4 py-2 rounded-lg transition">
            + MCQ Question
        </button>
        <button onclick="addQuestion('TrueFalse')"
                class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm px-4 py-2 rounded-lg transition">
            + True/False
        </button>
        <button onclick="saveQuiz()"
                class="ml-auto bg-orange-500 hover:bg-orange-600 text-white text-sm px-6 py-2 rounded-lg transition">
            Save Quiz
        </button>
    </div>
</div>

<script>
    const courseId = @Model.CourseId;
    let questionCount = 0;

    function addQuestion(type) {
        questionCount++;
        const qid = `q${questionCount}`;
        const container = document.getElementById('questionsContainer');

        let optionsHtml = '';
        if (type === 'TrueFalse') {
            optionsHtml = `
                <div class="space-y-2 mt-3">
                    <label class="flex items-center gap-2 text-sm">
                        <input type="radio" name="${qid}_correct" value="0" checked /> True
                    </label>
                    <label class="flex items-center gap-2 text-sm">
                        <input type="radio" name="${qid}_correct" value="1" /> False
                    </label>
                </div>`;
        } else {
            optionsHtml = `
                <div id="${qid}_options" class="space-y-2 mt-3">
                    ${mcqOption(qid, 0)}
                    ${mcqOption(qid, 1)}
                </div>
                <button onclick="addOption('${qid}')" class="mt-2 text-xs text-orange-500 hover:underline">+ Add option</button>`;
        }

        const div = document.createElement('div');
        div.className = 'bg-white rounded-2xl shadow-sm p-5';
        div.id = qid;
        div.dataset.type = type;
        div.innerHTML = `
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold uppercase text-orange-400">${type === 'TrueFalse' ? 'True / False' : 'MCQ'}</span>
                <button onclick="this.closest('[id]').remove()" class="text-xs text-red-400 hover:underline">Remove</button>
            </div>
            <input type="text" placeholder="Question text" id="${qid}_text"
                   class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            ${optionsHtml}
        `;
        container.appendChild(div);
    }

    function mcqOption(qid, index) {
        return `
            <label class="flex items-center gap-2 text-sm">
                <input type="radio" name="${qid}_correct" value="${index}" ${index === 0 ? 'checked' : ''} />
                <input type="text" placeholder="Option ${index + 1}" id="${qid}_opt${index}"
                       class="flex-1 border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </label>`;
    }

    function addOption(qid) {
        const container = document.getElementById(`${qid}_options`);
        const index = container.children.length;
        container.insertAdjacentHTML('beforeend', mcqOption(qid, index));
    }

    async function saveQuiz() {
        const title = document.getElementById('quizTitle').value.trim();
        const timer = parseInt(document.getElementById('quizTimer').value);

        if (!title) { alert('Please enter a quiz title.'); return; }

        const questionDivs = document.querySelectorAll('#questionsContainer > div');
        const questions = [];

        for (const qDiv of questionDivs) {
            const qid = qDiv.id;
            const type = qDiv.dataset.type;
            const text = document.getElementById(`${qid}_text`).value.trim();
            if (!text) { alert('All questions need text.'); return; }

            const correctRadio = qDiv.querySelector(`input[name="${qid}_correct"]:checked`);
            const correctIndex = correctRadio ? parseInt(correctRadio.value) : 0;

            let options = [];
            if (type === 'MCQ') {
                const optInputs = document.querySelectorAll(`#${qid}_options input[type=text]`);
                optInputs.forEach(o => options.push(o.value.trim()));
                if (options.some(o => !o)) { alert('Fill in all options.'); return; }
            }

            questions.push({ questionText: text, type, options, correctOptionIndex: correctIndex });
        }

        if (!questions.length) { alert('Add at least one question.'); return; }

        const res = await fetch('/Quiz/Create', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]').value
            },
            body: JSON.stringify({ courseId, title, totalMarks: parseInt(document.getElementById('quizMarks').value), timerMinutes: timer, questions })
        });

        if (res.ok) {
            const data = await res.json();
            window.location.href = `/Quiz/Index?courseId=${data.courseId}`;
        } else {
            alert('Failed to save quiz.');
        }
    }
</script>
