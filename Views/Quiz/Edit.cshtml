@model LMS.Models.Quiz
@using System.Text.Json
@{
    ViewData["Title"] = "Edit Quiz";
    ViewData["PageTitle"] = "Edit Quiz";
    ViewData["PageSubtitle"] = Model.Course?.Title;
    var initialQuestions = Model.Questions.OrderBy(q => q.Order).Select(q => new
    {
        questionText = q.QuestionText,
        type = q.Type,
        options = q.Type == "TrueFalse" ? Array.Empty<string>() : q.Options.Select(o => o.OptionText).ToArray(),
        correctOptionIndex = q.Options.OrderBy(o => o.Id).Select((o, i) => new { o, i }).FirstOrDefault(x => x.o.IsCorrect)?.i ?? 0
    });
}
<style>
  .input-field:focus { outline:none; border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.10); }
  .btn-primary { background:linear-gradient(135deg,#4f46e5,#6366f1); }
</style>
<div class="max-w-5xl mx-auto space-y-5">
  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 flex flex-wrap justify-between gap-4">
    <div><h2 class="text-lg font-bold text-slate-800">@Model.Title</h2><p class="text-sm text-slate-500">@Model.Course?.Title | @Model.Questions.Count questions | @Model.TotalMarks marks | @Model.TimerMinutes minutes</p></div>
    <div class="flex gap-2"><a asp-action="Index" asp-route-courseId="@Model.CourseId" class="text-sm font-medium text-slate-600 border border-slate-200 px-4 py-2 rounded-xl">Back to Quizzes</a><a asp-action="Results" asp-route-id="@Model.Id" class="text-sm font-medium text-indigo-600 border border-indigo-200 px-4 py-2 rounded-xl">View Attempts</a></div>
  </div>
  @if (Model.Attempts.Any())
  {
    <div class="bg-amber-50 border border-amber-200 text-amber-700 text-sm rounded-xl p-4">This quiz already has student attempts, so its questions are locked to preserve submitted results.</div>
  }
  else
  {
    <div class="grid lg:grid-cols-3 gap-5">
      <aside class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 h-fit">
        <h3 class="font-semibold text-slate-800 mb-4">Quiz Settings</h3>
        <label class="block text-xs font-semibold text-slate-500 uppercase mb-1.5">Title</label>
        <input id="quizTitle" value="@Model.Title" class="input-field w-full border border-slate-200 bg-slate-50 rounded-xl px-3 py-2.5 text-sm mb-4" />
        <label class="block text-xs font-semibold text-slate-500 uppercase mb-1.5">Total Marks</label>
        <input id="quizMarks" type="number" min="1" value="@Model.TotalMarks" class="input-field w-full border border-slate-200 bg-slate-50 rounded-xl px-3 py-2.5 text-sm mb-4" />
        <label class="block text-xs font-semibold text-slate-500 uppercase mb-1.5">Time Limit (minutes)</label>
        <input id="quizTimer" type="number" min="1" value="@Model.TimerMinutes" class="input-field w-full border border-slate-200 bg-slate-50 rounded-xl px-3 py-2.5 text-sm mb-5" />
        <button type="button" onclick="addQuestion('MCQ')" class="w-full text-sm text-indigo-600 bg-indigo-50 px-3 py-2.5 rounded-xl mb-2"><i class="ri-add-line"></i> Add Multiple Choice</button>
        <button type="button" onclick="addQuestion('TrueFalse')" class="w-full text-sm text-sky-600 bg-sky-50 px-3 py-2.5 rounded-xl"><i class="ri-add-line"></i> Add True / False</button>
      </aside>
      <section class="lg:col-span-2 space-y-4">
        <div id="questionsContainer" class="space-y-4"></div>
        <button type="button" onclick="saveQuiz()" class="btn-primary w-full text-white font-semibold py-3 rounded-xl"><i class="ri-save-line"></i> Save Quiz Changes</button>
      </section>
    </div>
  }
</div>
@if (!Model.Attempts.Any())
{
@section Scripts {
<script>
  const quizId = @Model.Id;
  const courseId = @Model.CourseId;
  const existing = @Html.Raw(JsonSerializer.Serialize(initialQuestions));
  let questionCount = 0;
  function mcqOption(id, index, value, correct) {
    return `<label class="flex gap-2 items-center"><input type="radio" name="${id}_correct" value="${index}" ${correct ? 'checked' : ''}/><input type="text" value="${value || ''}" placeholder="Option ${index + 1}" class="option flex-1 input-field border border-slate-200 rounded-xl px-3 py-2 text-sm"/></label>`;
  }
  function addQuestion(type, data = {}) {
    const id = 'q' + (++questionCount);
    const div = document.createElement('article');
    div.id = id; div.dataset.type = type; div.className = 'bg-white rounded-2xl border border-slate-100 shadow-sm p-5';
    let options = '';
    if (type === 'TrueFalse') {
      const correct = data.correctOptionIndex || 0;
      options = `<label class="flex gap-2 text-sm"><input type="radio" name="${id}_correct" value="0" ${correct === 0 ? 'checked' : ''}/> True</label><label class="flex gap-2 text-sm"><input type="radio" name="${id}_correct" value="1" ${correct === 1 ? 'checked' : ''}/> False</label>`;
    } else {
      const values = data.options && data.options.length ? data.options : ['', ''];
      options = `<div class="options space-y-2">${values.map((v, i) => mcqOption(id, i, v, i === (data.correctOptionIndex || 0))).join('')}</div><button type="button" onclick="addOption('${id}')" class="mt-2 text-xs text-primary-600">+ Add option</button>`;
    }
    div.innerHTML = `<div class="flex justify-between mb-3"><span class="text-xs font-semibold uppercase text-primary-600">${type === 'TrueFalse' ? 'True / False' : 'Multiple Choice'}</span><button type="button" onclick="document.getElementById('${id}').remove()" class="text-xs text-red-500">Delete</button></div><textarea class="question input-field w-full border border-slate-200 rounded-xl px-3 py-2 text-sm mb-3" rows="2" placeholder="Question text">${data.questionText || ''}</textarea><div class="space-y-2">${options}</div>`;
    document.getElementById('questionsContainer').appendChild(div);
  }
  function addOption(id) {
    const wrapper = document.querySelector('#' + id + ' .options');
    wrapper.insertAdjacentHTML('beforeend', mcqOption(id, wrapper.children.length, '', false));
  }
  existing.forEach(question => addQuestion(question.type, question));
  async function saveQuiz() {
    const questions = [];
    for (const card of document.querySelectorAll('#questionsContainer article')) {
      const questionText = card.querySelector('.question').value.trim();
      if (!questionText) { alert('Every question needs text.'); return; }
      const selected = card.querySelector('input[type=radio]:checked');
      const correctOptionIndex = selected ? parseInt(selected.value) : 0;
      const options = card.dataset.type === 'MCQ' ? Array.from(card.querySelectorAll('.option')).map(option => option.value.trim()) : [];
      if (card.dataset.type === 'MCQ' && (options.length < 2 || options.some(option => !option))) { alert('Fill in at least two options for each multiple-choice question.'); return; }
      questions.push({ questionText, type: card.dataset.type, options, correctOptionIndex });
    }
    if (!questions.length) { alert('Add at least one question.'); return; }
    const response = await fetch(`/Quiz/Edit/${quizId}`, { method:'POST', headers:{ 'Content-Type':'application/json' }, body:JSON.stringify({ courseId, title:document.getElementById('quizTitle').value.trim(), totalMarks:parseInt(document.getElementById('quizMarks').value), timerMinutes:parseInt(document.getElementById('quizTimer').value), questions }) });
    if (response.ok) window.location.href = `/Quiz/Index?courseId=${courseId}`; else alert(await response.text());
  }
</script>
}
}
