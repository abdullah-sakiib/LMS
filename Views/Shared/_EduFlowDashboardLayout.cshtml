@using LMS.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<LMS.Models.ApplicationUser> UserManager
@inject ApplicationDbContext Db
@{
    var currentUser = await UserManager.GetUserAsync(User);
    var name = currentUser?.FullName ?? "User";
    var initial = string.IsNullOrWhiteSpace(name) ? "U" : name[..1].ToUpperInvariant();
    var avatar = currentUser?.ProfilePicture;
    var role = User.IsInRole("Admin") ? "Administrator" : User.IsInRole("Instructor") ? "Instructor" : "Student";
    var isAdmin = User.IsInRole("Admin");
    var isInstructor = User.IsInRole("Instructor");
    var isStudent = User.IsInRole("Student");
    var dashboardController = isAdmin ? "Admin" : "Dashboard";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var onDashboard = (controller == "Dashboard" || controller == "Admin") && action == "Index";
    var onCourses = controller == "Course" || controller == "Content";
    var onCreateCourse = controller == "Course" && action == "Create";
    var onRequests = controller == "Enrollment";
    var onSubmissions = controller == "Grade" && action == "Submissions";
    var onAssignments = controller == "Assignment";
    var onQuizzes = controller == "Quiz";
    var onProgress = controller == "Progress";
    var onGrades = controller == "Grade";
    var onAnnouncements = controller == "Announcement";
    var onProfile = controller == "Profile";
    var onAdminUsers = controller == "Admin" && action == "Users";
    var onAdminCourses = controller == "Admin" && action == "Courses";
    LMS.Models.Announcement? latestAnnouncement = null;
    string? latestAnnouncementPreview = null;
    if (isStudent && currentUser != null)
    {
      var enrolledCourseIds = await Db.Enrollments
        .Where(item => item.StudentId == currentUser.Id && item.Status == "Approved")
        .Select(item => item.CourseId)
        .ToListAsync();
      latestAnnouncement = await Db.Announcements
        .Include(item => item.Course)
        .Include(item => item.Instructor)
        .Where(item => item.CourseId == null || enrolledCourseIds.Contains(item.CourseId.Value))
        .OrderByDescending(item => item.CreatedAt)
        .FirstOrDefaultAsync();
      if (latestAnnouncement != null)
      {
        var body = latestAnnouncement.Body ?? string.Empty;
        latestAnnouncementPreview = body.Length > 140 ? body[..140] + "..." : body;
      }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] - EduFlow</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
  <script>
    tailwind.config = {
      theme: { extend: {
        fontFamily: { sans: ['DM Sans', 'sans-serif'], serif: ['DM Serif Display', 'serif'] },
        colors: { primary: { 50:'#eef2ff',100:'#e0e7ff',200:'#c7d2fe',300:'#a5b4fc',400:'#818cf8',500:'#6366f1',600:'#4f46e5',700:'#4338ca',800:'#3730a3',900:'#312e81' } }
      }}
    }
  </script>
  <style>
    * { font-family: 'DM Sans', sans-serif; }
    #sidebar { transition: width .3s cubic-bezier(.4,0,.2,1); width:260px; }
    #sidebar.collapsed { width:72px; }
    #sidebar.collapsed .nav-label, #sidebar.collapsed .nav-section-label, #sidebar.collapsed .user-info, #sidebar.collapsed .logo-text { display:none; }
    #sidebar.collapsed .nav-item { justify-content:center; padding-left:0; padding-right:0; }
    .nav-item.active { background:linear-gradient(135deg,#4f46e5,#6366f1); color:white; box-shadow:0 4px 15px rgba(99,102,241,.35); }
    .nav-item.active .nav-icon { color:white; }
    .nav-item { position:relative; }
    .nav-tooltip { position:absolute; left:calc(100% + 12px); top:50%; transform:translate(-8px,-50%); background:#1e1b4b; color:white; font-size:12px; font-weight:500; padding:5px 10px; border-radius:6px; white-space:nowrap; opacity:0; pointer-events:none; transition:all .2s; z-index:100; }
    .nav-tooltip::before { content:''; position:absolute; right:100%; top:50%; transform:translateY(-50%); border:5px solid transparent; border-right-color:#1e1b4b; }
    #sidebar.collapsed .nav-item:hover .nav-tooltip { opacity:1; transform:translate(0,-50%); }
    ::-webkit-scrollbar { width:5px; } ::-webkit-scrollbar-track { background:#f1f5f9; } ::-webkit-scrollbar-thumb { background:#c7d2fe; border-radius:10px; }
    .page-content { animation:fadeInUp .4s ease both; }
    @@keyframes fadeInUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
    .badge-pulse { animation:pulseBadge 2s infinite; }
    @@keyframes pulseBadge { 0%,100% { box-shadow:0 0 0 0 rgba(99,102,241,.4); } 50% { box-shadow:0 0 0 6px rgba(99,102,241,0); } }
    .topbar-panel-shell { background:linear-gradient(180deg,#fff,#f8faff 55%,#fff); border-color:#e0e7ff; box-shadow:0 18px 40px rgba(79,70,229,.14); }
    .topbar-panel-item { transition:all .18s ease; }
    .topbar-panel-item:hover { background:linear-gradient(90deg,#eef2ff,#ecfeff); }
    #topbar-search:focus { outline:none; box-shadow:0 0 0 3px rgba(99,102,241,.15); }
    #user-dropdown, #notif-panel { transition:all .2s ease; transform-origin:top right; }
    #user-dropdown.hidden, #notif-panel.hidden { transform:scale(.95); opacity:0; pointer-events:none; }
    body.harmony-theme { background:linear-gradient(180deg,#f8faff,#f9fbff 45%,#f8fbff); }
    body.harmony-theme main { background:transparent; }
    body.harmony-theme .bg-white.rounded-2xl, body.harmony-theme .bg-white.rounded-xl { background:linear-gradient(180deg,#fff,#f8faff); border-color:#e0e7ff; box-shadow:0 10px 28px rgba(79,70,229,.06); }
    body.harmony-theme .bg-indigo-600 { background:linear-gradient(135deg,#4f46e5,#6366f1); }
    body.harmony-theme .text-indigo-600, body.harmony-theme .text-primary-600 { color:#4f46e5; }
    body.harmony-theme .border-indigo-200, body.harmony-theme .border-slate-100 { border-color:#e0e7ff; }
  </style>
  @await RenderSectionAsync("DashboardStyles", required: false)
</head>
<body class="harmony-theme bg-slate-50 text-slate-800 flex h-screen overflow-hidden">
  <aside id="sidebar" class="bg-white border-r border-slate-100 flex flex-col h-screen overflow-hidden shadow-sm z-30 flex-shrink-0">
    <a asp-controller="@dashboardController" asp-action="Index" class="flex items-center gap-3 px-5 py-5 border-b border-slate-100">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center flex-shrink-0 shadow-md"><i class="ri-graduation-cap-fill text-white text-lg"></i></div>
      <span class="logo-text font-semibold text-slate-800 text-lg tracking-tight">EduFlow</span>
    </a>
    <div class="user-info flex items-center gap-3 px-5 py-4 border-b border-slate-100">
      <div class="relative flex-shrink-0">
        @if (!string.IsNullOrWhiteSpace(avatar))
        {
          <img src="@avatar" alt="Profile photo" class="w-9 h-9 rounded-full object-cover" />
        }
        else
        {
          <div class="w-9 h-9 rounded-full bg-primary-600 flex items-center justify-center text-white text-sm font-semibold">@initial</div>
        }
        <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-emerald-400 rounded-full border-2 border-white"></span>
      </div>
      <div class="overflow-hidden"><p class="text-sm font-semibold text-slate-800 truncate">@name</p><p class="text-xs text-primary-500 font-medium">@role</p></div>
    </div>
    <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-1">
      <p class="nav-section-label text-xs font-semibold text-slate-400 uppercase tracking-widest px-3 mb-2">Main Menu</p>
      <a asp-controller="@dashboardController" asp-action="Index" class="nav-item @(onDashboard ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all">
        <i class="nav-icon ri-dashboard-line text-xl flex-shrink-0"></i><span class="nav-label text-sm font-medium">Dashboard</span><span class="nav-tooltip">Dashboard</span>
      </a>
      <a asp-controller="Course" asp-action="Index" class="nav-item @(onCourses && !onCreateCourse ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all">
        <i class="nav-icon ri-book-open-line text-xl flex-shrink-0"></i><span class="nav-label text-sm font-medium">@(isStudent ? "Course Catalog" : "My Courses")</span><span class="nav-tooltip">Courses</span>
      </a>
      @if (isInstructor || isAdmin)
      {
        <a asp-controller="Course" asp-action="Create" class="nav-item @(onCreateCourse ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-add-circle-line text-xl"></i><span class="nav-label text-sm font-medium">Create Course</span><span class="nav-tooltip">Create Course</span></a>
        <a asp-controller="Assignment" asp-action="Index" class="nav-item @(onAssignments ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-file-list-3-line text-xl"></i><span class="nav-label text-sm font-medium">Assignments</span><span class="nav-tooltip">Assignments</span></a>
        <a asp-controller="Quiz" asp-action="Index" class="nav-item @(onQuizzes ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-questionnaire-line text-xl"></i><span class="nav-label text-sm font-medium">Quizzes</span><span class="nav-tooltip">Quizzes</span></a>
        <a asp-controller="Grade" asp-action="Submissions" class="nav-item @(onSubmissions ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-file-check-line text-xl"></i><span class="nav-label text-sm font-medium">Submissions</span><span class="nav-tooltip">Submissions</span></a>
        <a asp-controller="Enrollment" asp-action="Requests" class="nav-item @(onRequests ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-user-add-line text-xl"></i><span class="nav-label text-sm font-medium">Enrollment Requests</span><span class="nav-tooltip">Requests</span></a>
      }
      @if (isStudent)
      {
        <a asp-controller="Assignment" asp-action="Index" class="nav-item @(onAssignments ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-file-list-3-line text-xl"></i><span class="nav-label text-sm font-medium">Assignments</span><span class="nav-tooltip">Assignments</span></a>
        <a asp-controller="Quiz" asp-action="Index" class="nav-item @(onQuizzes ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-questionnaire-line text-xl"></i><span class="nav-label text-sm font-medium">Quizzes</span><span class="nav-tooltip">Quizzes</span></a>
        <a asp-controller="Progress" asp-action="Index" class="nav-item @(onProgress ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-file-list-3-line text-xl"></i><span class="nav-label text-sm font-medium">Progress</span><span class="nav-tooltip">Progress</span></a>
        <a asp-controller="Grade" asp-action="MyGrades" class="nav-item @(onGrades ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-bar-chart-box-line text-xl"></i><span class="nav-label text-sm font-medium">Grades</span><span class="nav-tooltip">Grades</span></a>
      }
      <a asp-controller="Announcement" asp-action="MyFeed" class="nav-item @(onAnnouncements ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-megaphone-line text-xl"></i><span class="nav-label text-sm font-medium">Announcements</span><span class="nav-tooltip">Announcements</span></a>
      @if (isAdmin)
      {
        <p class="nav-section-label text-xs font-semibold text-slate-400 uppercase tracking-widest px-3 pt-4 mb-2">Admin</p>
        <a asp-controller="Admin" asp-action="Users" class="nav-item @(onAdminUsers ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-group-line text-xl"></i><span class="nav-label text-sm font-medium">Manage Users</span><span class="nav-tooltip">Users</span></a>
        <a asp-controller="Admin" asp-action="Courses" class="nav-item @(onAdminCourses ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-settings-3-line text-xl"></i><span class="nav-label text-sm font-medium">Manage Courses</span><span class="nav-tooltip">Courses</span></a>
      }
      <p class="nav-section-label text-xs font-semibold text-slate-400 uppercase tracking-widest px-3 pt-4 mb-2">Account</p>
      <a asp-controller="Profile" asp-action="Index" class="nav-item @(onProfile ? "active" : "text-slate-600 hover:bg-primary-50 hover:text-primary-600") flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"><i class="nav-icon ri-user-line text-xl"></i><span class="nav-label text-sm font-medium">Profile</span><span class="nav-tooltip">Profile</span></a>
    </nav>
    <div class="p-3 border-t border-slate-100">
      <form asp-controller="Account" asp-action="Logout" method="post">
        <button type="submit" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-xl text-red-400 hover:bg-red-50 hover:text-red-500 transition-all w-full"><i class="nav-icon ri-logout-box-r-line text-xl"></i><span class="nav-label text-sm font-medium">Logout</span><span class="nav-tooltip">Logout</span></button>
      </form>
    </div>
  </aside>
  <div class="flex flex-col flex-1 overflow-hidden">
    <header class="bg-gradient-to-r from-white via-indigo-50/60 to-cyan-50/50 border-b border-slate-100 px-6 py-3.5 flex items-center gap-4 z-20 shadow-sm">
      <button type="button" onclick="toggleSidebar()" class="w-9 h-9 flex items-center justify-center rounded-xl hover:bg-primary-50 text-slate-500 hover:text-primary-600 transition"><i class="ri-menu-fold-line text-xl" id="toggle-icon"></i></button>
      <div class="flex-shrink-0"><h1 class="text-base font-semibold text-slate-800">@(ViewData["PageTitle"] ?? ViewData["Title"] ?? "Dashboard")</h1><p class="text-xs text-slate-400">@(ViewData["PageSubtitle"] ?? "Welcome back!")</p></div>
      <form asp-controller="Course" asp-action="Index" method="get" class="flex-1 max-w-md mx-auto relative"><i class="ri-search-line absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i><input id="topbar-search" name="q" value="@Context.Request.Query["q"]" type="text" placeholder="Search courses..." class="w-full pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 placeholder-slate-400 transition-all focus:bg-white focus:border-primary-300"/></form>
      <div class="relative">
        <button id="notif-btn" type="button" onclick="toggleNotif()" class="w-9 h-9 flex items-center justify-center rounded-xl hover:bg-primary-100 text-slate-500 relative"><i class="ri-notification-3-line text-xl"></i><span class="badge-pulse absolute top-1.5 right-1.5 w-2 h-2 bg-primary-500 rounded-full"></span></button>
        <div id="notif-panel" class="topbar-panel-shell hidden absolute right-0 top-12 w-80 rounded-2xl border overflow-hidden z-50">
          <div class="px-4 py-3 border-b border-indigo-100 bg-gradient-to-r from-indigo-50 to-cyan-50"><h3 class="font-semibold text-slate-800 text-sm">Notifications</h3></div>
          @if (isStudent)
          {
            if (latestAnnouncement != null)
            {
              <div class="px-4 py-4 space-y-2">
                <p class="text-xs text-slate-400 uppercase tracking-wide">Latest announcement</p>
                <p class="text-sm font-semibold text-slate-800">@latestAnnouncement.Title</p>
                <p class="text-xs text-slate-500">@(latestAnnouncement.IsGlobal ? "Global" : latestAnnouncement.Course?.Title ?? "General") | @(latestAnnouncement.Instructor?.FullName ?? "System")</p>
                <p class="text-sm text-slate-600 leading-relaxed">@latestAnnouncementPreview</p>
                <p class="text-[11px] text-slate-400">@latestAnnouncement.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
              </div>
            }
            else
            {
              <div class="px-4 py-6 text-center"><p class="text-sm text-slate-500">No announcements yet.</p></div>
            }
            <div class="px-4 py-3 border-t border-indigo-100 text-center bg-indigo-50/70"><a asp-controller="Announcement" asp-action="MyFeed" class="text-xs text-primary-600 font-semibold hover:underline">View announcements</a></div>
          }
          else
          {
            <div class="px-4 py-6 text-center"><p class="text-sm text-slate-500">Course announcements are available in the announcements page.</p></div>
          }
        </div>
      </div>
      <div class="relative">
        <button id="user-btn" type="button" onclick="toggleUserMenu()" class="flex items-center gap-2 pl-2 pr-3 py-1.5 rounded-xl border border-transparent hover:border-indigo-100 hover:bg-indigo-50 transition">
          @if (!string.IsNullOrWhiteSpace(avatar))
          {
            <img src="@avatar" alt="Profile photo" class="w-8 h-8 rounded-full object-cover" />
          }
          else
          {
            <div class="w-8 h-8 rounded-full bg-primary-600 flex items-center justify-center text-white text-xs font-semibold">@initial</div>
          }
          <div class="hidden sm:block text-left"><p class="text-xs font-semibold text-slate-700">@name</p><p class="text-xs text-slate-400">@role</p></div><i class="ri-arrow-down-s-line text-slate-400 text-sm"></i>
        </button>
        <div id="user-dropdown" class="topbar-panel-shell hidden absolute right-0 top-12 w-52 rounded-2xl border overflow-hidden z-50">
          <div class="px-4 py-3 border-b border-indigo-100 bg-gradient-to-r from-indigo-50 to-cyan-50"><p class="text-sm font-semibold text-slate-800">@name</p><p class="text-xs text-slate-400">@currentUser?.Email</p></div>
          <div class="py-1"><a asp-controller="Profile" asp-action="Index" class="topbar-panel-item flex items-center gap-2 px-4 py-2.5 text-sm text-slate-600 hover:text-primary-600"><i class="ri-user-line"></i> Profile</a><a asp-controller="Course" asp-action="Index" class="topbar-panel-item flex items-center gap-2 px-4 py-2.5 text-sm text-slate-600 hover:text-primary-600"><i class="ri-book-open-line"></i> My Courses</a></div>
          <div class="border-t border-indigo-100 py-1 bg-rose-50/30"><form asp-controller="Account" asp-action="Logout" method="post"><button type="submit" class="w-full text-left flex items-center gap-2 px-4 py-2.5 text-sm text-red-500 hover:bg-red-50"><i class="ri-logout-box-r-line"></i> Logout</button></form></div>
        </div>
      </div>
    </header>
    <main class="flex-1 overflow-y-auto bg-slate-50"><div class="page-content p-6">
      @if (TempData["Success"] is string success)
      {
        <div class="global-flash-message rounded-xl px-4 py-3 text-sm border mb-4 transition-all duration-500 bg-emerald-50 text-emerald-700 border-emerald-100">@success</div>
      }
      @if (TempData["Error"] is string error)
      {
        <div class="global-flash-message rounded-xl px-4 py-3 text-sm border mb-4 transition-all duration-500 bg-red-50 text-red-700 border-red-100">@error</div>
      }
      @RenderBody()
    </div></main>
  </div>
  <script>
    const sidebar = document.getElementById('sidebar');
    const toggleIcon = document.getElementById('toggle-icon');
    function toggleSidebar() {
      const collapsed = sidebar.classList.toggle('collapsed');
      toggleIcon.className = collapsed ? 'ri-menu-unfold-line text-xl' : 'ri-menu-fold-line text-xl';
      localStorage.setItem('sidebarCollapsed', collapsed);
    }
    if (localStorage.getItem('sidebarCollapsed') === 'true') { sidebar.classList.add('collapsed'); toggleIcon.className = 'ri-menu-unfold-line text-xl'; }
    const notifPanel = document.getElementById('notif-panel');
    const userDropdown = document.getElementById('user-dropdown');
    function toggleNotif() {
      notifPanel.classList.toggle('hidden');
      userDropdown.classList.add('hidden');
    }
    function toggleUserMenu() {
      userDropdown.classList.toggle('hidden');
      notifPanel.classList.add('hidden');
    }
    document.addEventListener('click', event => {
      if (!event.target.closest('#notif-btn') && !event.target.closest('#notif-panel')) notifPanel.classList.add('hidden');
      if (!event.target.closest('#user-btn') && !event.target.closest('#user-dropdown')) userDropdown.classList.add('hidden');
    });
    document.addEventListener('keydown', event => {
      if (event.key === '/' && document.activeElement.tagName !== 'INPUT') {
        event.preventDefault();
        document.getElementById('topbar-search').focus();
      }
    });
    document.querySelectorAll('.global-flash-message').forEach((message, index) => {
      setTimeout(() => { message.classList.add('opacity-0', '-translate-y-1'); setTimeout(() => message.remove(), 500); }, 3000 + index * 200);
    });
  </script>
  @await RenderSectionAsync("DashboardScripts", required: false)
</body>
</html>
