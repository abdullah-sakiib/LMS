@model List<LMS.Models.Course>
@{
    ViewData["Title"] = "Manage Courses";
}

<div class="max-w-5xl mx-auto">
    <h2 class="text-xl font-bold text-gray-800 mb-5">Manage Courses</h2>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 rounded-xl">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-xl">
            @TempData["Error"]
        </div>
    }

    <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
                <tr>
                    <th class="px-5 py-3 text-left">Title</th>
                    <th class="px-5 py-3 text-left">Instructor</th>
                    <th class="px-5 py-3 text-left">Status</th>
                    <th class="px-5 py-3 text-left">Enrolled</th>
                    <th class="px-5 py-3 text-left">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="px-5 py-3 font-medium text-gray-800">@c.Title</td>
                        <td class="px-5 py-3 text-gray-500">@c.Instructor?.FullName</td>
                        <td class="px-5 py-3">
                            <span class="px-2 py-0.5 rounded-full text-xs font-medium
                                @(c.Status == "Published" ? "bg-green-100 text-green-600" :
                                                                    c.Status == "Archived" ? "bg-gray-100 text-gray-500" :
                                                                    "bg-yellow-100 text-yellow-600")">
                                @c.Status
                            </span>
                        </td>
                        <td class="px-5 py-3 text-gray-500">@c.Enrollments.Count</td>
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-3">
                                <a asp-controller="Course" asp-action="Details" asp-route-id="@c.Id"
                                   class="text-xs text-orange-500 hover:underline">View</a>
                                <form asp-action="DeleteCourse" method="post"
                                      onsubmit="return confirm('Delete this course and all its data?')">
                                    <input type="hidden" name="courseId" value="@c.Id" />
                                    <button type="submit" class="text-xs text-red-400 hover:underline">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
