@model List<LMS.Models.Enrollment>
@{
    ViewData["Title"] = "Enrollment Requests";
}

<div class="max-w-4xl mx-auto">
    <h2 class="text-xl font-bold text-gray-800 mb-6">Pending Enrollment Requests</h2>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-2xl p-10 text-center shadow-sm">
            <p class="text-gray-400">No pending requests.</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-500 text-left">
                    <tr>
                        <th class="px-6 py-3">Student</th>
                        <th class="px-6 py-3">Course</th>
                        <th class="px-6 py-3">Requested</th>
                        <th class="px-6 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td class="px-6 py-4">
                                <p class="font-medium text-gray-800">@e.Student?.FullName</p>
                                <p class="text-gray-400 text-xs">@e.Student?.Email</p>
                            </td>
                            <td class="px-6 py-4 text-gray-700">@e.Course?.Title</td>
                            <td class="px-6 py-4 text-gray-400">@e.EnrolledAt.ToShortDateString()</td>
                            <td class="px-6 py-4 flex gap-2">
                                <form asp-action="Approve" asp-route-id="@e.Id" method="post">
                                    <button type="submit"
                                            class="bg-green-100 hover:bg-green-200 text-green-700 px-3 py-1 rounded-lg transition text-xs font-medium">
                                        Approve
                                    </button>
                                </form>
                                <form asp-action="Reject" asp-route-id="@e.Id" method="post">
                                    <button type="submit"
                                            class="bg-red-100 hover:bg-red-200 text-red-600 px-3 py-1 rounded-lg transition text-xs font-medium">
                                        Reject
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>