@model LMS.ViewModels.DashboardVM
@{
    Layout = "_EduFlowDashboardLayout";
    ViewData["Title"] = Model.Role == "Instructor" ? "Instructor Dashboard" : "Student Dashboard";
    ViewData["PageTitle"] = Model.Role == "Instructor" ? "Instructor Dashboard" : "Dashboard";
    ViewData["PageSubtitle"] = Model.Role == "Instructor" ? "Manage courses and student submissions" : $"Welcome back, {Model.FullName}";
}
@section DashboardStyles {
<style>
  .hero-orb { position:absolute; border-radius:9999px; filter:blur(2px); opacity:.4; }
  .dashboard-card, .dash-card { transition:transform .22s ease, box-shadow .22s ease; }
  .dashboard-card:hover, .dash-card:hover { transform:translateY(-3px); box-shadow:0 14px 30px rgba(15,23,42,.08); }
</style>
}
@if (Model.Role == "Instructor")
{
  <div class="max-w-6xl mx-auto space-y-5">
    <section class="relative overflow-hidden rounded-3xl border border-slate-100 bg-gradient-to-br from-cyan-100 via-indigo-100 to-fuchsia-100 p-6">
      <span class="hero-orb w-32 h-32 bg-cyan-300 top-0 -left-8"></span><span class="hero-orb w-40 h-40 bg-fuchsia-300 bottom-0 right-8"></span>
      <div class="relative flex items-end justify-between gap-4 flex-wrap">
        <div><p class="text-xs uppercase tracking-[0.2em] font-semibold text-indigo-700">Instructor Hub</p><h2 class="text-2xl font-bold text-slate-800 mt-1">Teach With Clarity And Speed</h2><p class="text-sm text-slate-600 mt-1">Manage course delivery, review submissions, and keep learners moving.</p></div>
        <a asp-controller="Course" asp-action="Create" class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-2 rounded-xl bg-white/80 border border-white text-slate-700 hover:bg-white transition"><i class="ri-add-circle-line"></i> New Course</a>
      </div>
    </section>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="dash-card rounded-2xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-blue-100 p-4"><p class="text-xs text-indigo-700 font-semibold">Courses</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.TotalCourses</p></div>
      <div class="dash-card rounded-2xl border border-emerald-200 bg-gradient-to-br from-emerald-50 to-lime-100 p-4"><p class="text-xs text-emerald-700 font-semibold">Students</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.TotalStudents</p></div>
      <div class="dash-card rounded-2xl border border-amber-200 bg-gradient-to-br from-amber-50 to-orange-100 p-4"><p class="text-xs text-amber-700 font-semibold">Pending Submissions</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.PendingSubmissions</p></div>
      <div class="dash-card rounded-2xl border border-violet-200 bg-gradient-to-br from-violet-50 to-fuchsia-100 p-4"><p class="text-xs text-violet-700 font-semibold">Average Student Completion</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.Completion.ToString("0")%</p></div>
    </div>
    <div class="grid lg:grid-cols-2 gap-5">
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between"><h3 class="font-semibold text-slate-800">My Courses</h3><a asp-controller="Course" asp-action="Create" class="text-sm font-semibold text-indigo-600">Create</a></div>
        <div class="divide-y divide-slate-100">
          @foreach (var course in Model.Courses)
          {
            <a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id" class="block px-5 py-4 hover:bg-indigo-50 transition"><p class="font-medium text-slate-800">@course.Title</p><p class="text-xs text-slate-500 mt-1">@course.Status | @course.EnrollmentCount students</p></a>
          }
          @if (!Model.Courses.Any()) { <div class="px-5 py-8 text-center text-slate-500 text-sm">No courses yet.</div> }
        </div>
      </div>
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between"><h3 class="font-semibold text-slate-800">Pending Reviews</h3><a asp-controller="Grade" asp-action="Submissions" class="text-sm font-semibold text-indigo-600">Open grading</a></div>
        <div class="divide-y divide-slate-100">
          @foreach (var submission in Model.PendingReviews)
          {
            <div class="px-5 py-4 hover:bg-amber-50 transition"><p class="font-medium text-slate-800">@submission.AssignmentTitle</p><p class="text-xs text-slate-500 mt-1">@submission.StudentName | @submission.CourseTitle</p></div>
          }
          @if (!Model.PendingReviews.Any()) { <div class="px-5 py-8 text-center text-slate-500 text-sm">No pending submissions.</div> }
        </div>
      </div>
    </div>
    <div class="grid lg:grid-cols-3 gap-5">
      <section class="lg:col-span-2 bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
        <div class="flex items-center justify-between mb-4"><h3 class="font-semibold text-slate-800">Top Students In Your Courses</h3><span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-emerald-100 text-emerald-700">Ranked by performance</span></div>
        <table class="w-full text-sm">
          <thead><tr class="text-xs uppercase tracking-wide text-slate-500 border-b border-slate-100"><th class="text-left py-2 pr-3">Student</th><th class="text-left py-2">Courses</th></tr></thead>
          <tbody class="divide-y divide-slate-100">
            @foreach (var student in Model.TopStudents) { <tr class="hover:bg-indigo-50/70"><td class="py-3 pr-3 font-semibold text-slate-800">@student.Name</td><td class="py-3 text-slate-700">@student.Courses</td></tr> }
            @if (!Model.TopStudents.Any()) { <tr><td colspan="2" class="py-6 text-center text-slate-500">No student performance data available yet.</td></tr> }
          </tbody>
        </table>
      </section>
      <section class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
        <div class="flex items-center justify-between mb-4"><h3 class="font-semibold text-slate-800">Student Opinions</h3><i class="ri-chat-quote-line text-pink-500"></i></div>
        <div class="rounded-xl border border-pink-100 bg-gradient-to-r from-pink-50 to-rose-50 p-4 text-sm text-slate-500">Course feedback will appear here.</div>
      </section>
    </div>
  </div>
}
else
{
  <div class="max-w-7xl mx-auto space-y-6">
    <section class="relative overflow-hidden rounded-3xl border border-slate-100 bg-gradient-to-br from-orange-100 via-rose-50 to-sky-100 p-6">
      <span class="hero-orb w-32 h-32 bg-orange-300 top-0 -left-8"></span><span class="hero-orb w-40 h-40 bg-sky-300 bottom-0 right-10"></span><span class="hero-orb w-24 h-24 bg-rose-300 top-10 right-1/3"></span>
      <div class="relative flex flex-wrap items-end justify-between gap-4">
        <div><p class="text-xs uppercase tracking-[0.2em] font-semibold text-rose-700">Student Snapshot</p><h2 class="text-2xl font-bold text-slate-800 mt-1">Keep Your Momentum, @Model.FullName</h2><p class="text-sm text-slate-600 mt-1">Track progress, discover trending courses, and learn from top instructors.</p></div>
        <a asp-controller="Course" asp-action="Index" class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-2 rounded-xl bg-white/80 border border-white text-slate-700 hover:bg-white transition"><i class="ri-compass-3-line"></i> Explore Catalog</a>
      </div>
    </section>
    <div class="grid sm:grid-cols-2 xl:grid-cols-6 gap-4">
      <div class="dashboard-card rounded-2xl border border-orange-200 bg-gradient-to-br from-orange-50 to-amber-100 p-5"><p class="text-xs text-orange-700 font-semibold">Enrolled Courses</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.EnrolledCourses</p></div>
      <div class="dashboard-card rounded-2xl border border-rose-200 bg-gradient-to-br from-rose-50 to-pink-100 p-5"><p class="text-xs text-rose-700 font-semibold">Pending Assignments</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.PendingAssignments</p></div>
      <div class="dashboard-card rounded-2xl border border-sky-200 bg-gradient-to-br from-sky-50 to-cyan-100 p-5"><p class="text-xs text-sky-700 font-semibold">Pending Quizzes</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.PendingQuizzes</p></div>
      <div class="dashboard-card rounded-2xl border border-violet-200 bg-gradient-to-br from-violet-50 to-fuchsia-100 p-5"><p class="text-xs text-violet-700 font-semibold">Assignment Marks</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.AssignmentMarks.ToString("0")%</p></div>
      <div class="dashboard-card rounded-2xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-blue-100 p-5"><p class="text-xs text-indigo-700 font-semibold">Quiz Marks</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.QuizMarks.ToString("0")%</p></div>
      <div class="dashboard-card rounded-2xl border border-emerald-200 bg-gradient-to-br from-emerald-50 to-lime-100 p-5"><p class="text-xs text-emerald-700 font-semibold">Average Progress</p><p class="text-2xl font-bold text-slate-800 mt-1">@Model.Completion.ToString("0")%</p></div>
    </div>
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
      <div class="flex items-center justify-between mb-4"><h2 class="text-base font-semibold text-slate-800">My Courses</h2><a asp-controller="Course" asp-action="Index" class="text-sm text-indigo-600 hover:text-indigo-700">Browse Catalog</a></div>
      <div class="space-y-3">
        @foreach (var course in Model.Courses)
        {
          <details class="dashboard-card border border-slate-100 hover:border-indigo-200 rounded-xl p-4 transition bg-gradient-to-r from-white to-slate-50">
            <summary class="list-none cursor-pointer">
              <div class="flex items-center justify-between gap-3"><div><a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id" class="font-semibold text-slate-800 hover:text-indigo-600">@course.Title</a><p class="text-xs text-slate-500 mt-1">Instructor: @course.Instructor</p></div><div class="text-right min-w-20"><p class="text-sm font-semibold text-slate-700">@course.Progress%</p><p class="text-xs text-slate-400">Progress</p></div></div>
              <div class="mt-3 h-2 bg-slate-100 rounded-full overflow-hidden"><div class="h-full bg-indigo-500 rounded-full" style="width:@course.Progress%"></div></div>
            </summary>
            <div class="mt-4 grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
              <div class="rounded-xl border border-violet-200 p-3 bg-violet-50"><p class="text-xs text-violet-700">Assignment Marks</p><p class="text-lg font-bold text-slate-800 mt-1">@course.AssignmentAverage.ToString("0")%</p><p class="text-xs text-slate-400 mt-1">@course.AssignmentSubmitted/@course.AssignmentTotal submitted</p></div>
              <div class="rounded-xl border border-indigo-200 p-3 bg-indigo-50"><p class="text-xs text-indigo-700">Quiz Marks</p><p class="text-lg font-bold text-slate-800 mt-1">@course.QuizAverage.ToString("0")%</p><p class="text-xs text-slate-400 mt-1">@course.QuizCompleted/@course.QuizTotal completed</p></div>
              <div class="rounded-xl border border-amber-200 p-3 bg-amber-50"><p class="text-xs text-amber-700">Assignments Pending</p><p class="text-lg font-bold text-amber-700 mt-1">@course.AssignmentPending</p></div>
              <div class="rounded-xl border border-sky-200 p-3 bg-sky-50"><p class="text-xs text-sky-700">Quizzes Pending</p><p class="text-lg font-bold text-sky-700 mt-1">@course.QuizPending</p></div>
            </div>
            <div class="mt-3 flex flex-wrap gap-2"><a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id" class="inline-flex items-center px-3 py-2 text-xs font-semibold rounded-lg border border-indigo-200 text-indigo-600 hover:bg-indigo-50">Open Course</a><a asp-controller="Assignment" asp-action="Index" asp-route-courseId="@course.Id" class="inline-flex items-center px-3 py-2 text-xs font-semibold rounded-lg border border-slate-200 text-slate-600">Assignments</a><a asp-controller="Quiz" asp-action="Index" asp-route-courseId="@course.Id" class="inline-flex items-center px-3 py-2 text-xs font-semibold rounded-lg border border-slate-200 text-slate-600">Quizzes</a></div>
          </details>
        }
        @if (!Model.Courses.Any()) { <div class="text-center py-8"><p class="font-semibold text-slate-700">No enrolled courses yet</p><p class="text-sm text-slate-400 mt-1">Enroll in courses created by instructors from the course catalog.</p></div> }
      </div>
    </div>
    <div class="grid lg:grid-cols-3 gap-5">
      <section class="lg:col-span-2 bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
        <div class="flex items-center justify-between mb-4"><h2 class="text-base font-semibold text-slate-800">Popular Courses</h2><a asp-controller="Course" asp-action="Index" class="text-sm text-indigo-600">View all</a></div>
        <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-3">
          @foreach (var course in Model.PopularCourses) { <a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id" class="dashboard-card rounded-xl border border-slate-100 p-4 bg-gradient-to-br from-indigo-50 to-blue-100"><p class="text-sm font-semibold text-slate-800">@course.Title</p><p class="text-xs text-slate-600 mt-1">@course.Instructor</p><p class="mt-3 text-xs text-slate-600"><i class="ri-group-line mr-1"></i>@course.EnrollmentCount students</p></a> }
          @if (!Model.PopularCourses.Any()) { <p class="text-sm text-slate-500">No popular courses available yet.</p> }
        </div>
      </section>
      <section class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
        <h2 class="text-base font-semibold text-slate-800 mb-4">Top Instructors</h2>
        <div class="space-y-3">
          @foreach (var instructor in Model.TopInstructors) { <div class="dashboard-card rounded-xl border border-slate-100 p-3 bg-gradient-to-r from-orange-50 to-white"><p class="text-sm font-semibold text-slate-800">@instructor.Name</p><p class="text-xs text-slate-500 mt-0.5">@instructor.Courses courses | @instructor.Students students</p></div> }
          @if (!Model.TopInstructors.Any()) { <p class="text-sm text-slate-500">No instructor stats available yet.</p> }
        </div>
      </section>
    </div>
  </div>
}
