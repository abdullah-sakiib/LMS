@model LMS.ViewModels.CourseDetailsVM
@{
    var course = Model.Course;
    var enrolled = Model.Enrollment?.Status == "Approved";
    var pending = Model.Enrollment?.Status == "Pending";
    var isAdmin = User.IsInRole("Admin");
    var canTeachCourse = User.IsInRole("Instructor") && Model.IsCourseStaff;
    ViewData["Title"] = course.Title;
    ViewData["PageTitle"] = course.Title;
    ViewData["PageSubtitle"] = "Course details";
}
<style>
  .detail-card { background:linear-gradient(180deg,#fff,#f8faff); border-color:#e0e7ff; }
  .detail-link:hover { background:linear-gradient(90deg,#eef2ff,#ecfeff); }
</style>
<div class="max-w-7xl mx-auto grid lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-5">
    <div class="detail-card rounded-2xl border shadow-sm p-6">
      <h1 class="text-2xl font-bold text-slate-800">@course.Title</h1>
      @if (!string.IsNullOrWhiteSpace(course.ShortDescription))
      {
        <p class="text-sm text-slate-500 mt-2">@course.ShortDescription</p>
      }
      <div class="mt-3 flex flex-wrap items-center gap-3 text-xs">
        <span class="px-2.5 py-1 rounded-full bg-amber-50 text-amber-700 font-semibold"><i class="ri-star-fill mr-1"></i> Course @Model.CourseRating.ToString("0.0") (@Model.CourseReviewCount)</span>
        <span class="px-2.5 py-1 rounded-full bg-indigo-50 text-indigo-700 font-semibold"><i class="ri-user-star-line mr-1"></i> Instructor @Model.InstructorRating.ToString("0.0") (@Model.InstructorReviewCount)</span>
        @if (course.IsEnded) { <span class="px-2.5 py-1 rounded-full bg-rose-50 text-rose-700 font-semibold"><i class="ri-flag-line mr-1"></i> Ended @course.EndedAt?.ToString("MMM dd, yyyy")</span> }
      </div>
      <div class="mt-4 grid sm:grid-cols-2 gap-3 text-sm text-slate-600">
        <p><strong>Category:</strong> @(!string.IsNullOrWhiteSpace(course.Category) ? course.Category : "General")</p>
        <p><strong>Level:</strong> @course.Level</p>
        <p><strong>Duration:</strong> @course.DurationWeeks weeks</p>
        <p><strong>Instructor:</strong> @(course.Instructor?.FullName ?? "TBA")</p>
        <p><strong>Enrollment:</strong> @(course.EnrollmentType == "Approval" ? "Approval required" : "Open")</p>
        <p><strong>Capacity:</strong> @Model.ApprovedEnrollmentCount / @course.Capacity</p>
      </div>
      @if (course.TagList.Any()) { <div class="mt-4 flex flex-wrap gap-2">@foreach (var tag in course.TagList) { <span class="px-2.5 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-medium">#@tag</span> }</div> }
      @if (!string.IsNullOrWhiteSpace(course.Description)) { <div class="mt-4 text-sm text-slate-700 leading-relaxed whitespace-pre-line">@course.Description</div> }
    </div>
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
      <div class="flex items-center justify-between mb-4"><h2 class="font-semibold text-slate-800">Modules</h2><span class="text-xs text-slate-500">@course.Modules.Count modules - @Model.ResourceCount resources</span></div>
      <div class="space-y-3">
        @foreach (var module in course.Modules.OrderBy(item => item.Order))
        {
          <div class="border border-indigo-100 rounded-xl p-4 bg-white/80">
            <p class="font-semibold text-slate-800">@module.Title</p>
            <div class="mt-3 space-y-2">
              @foreach (var resource in module.ContentItems.OrderBy(item => item.Order)) { <div class="text-sm text-slate-700 flex items-center justify-between gap-3"><span>@resource.Title</span><span class="text-xs text-slate-500">@resource.Type</span></div> }
              @if (!module.ContentItems.Any()) { <p class="text-sm text-slate-400">No resources in this module yet.</p> }
            </div>
          </div>
        }
        @if (!course.Modules.Any()) { <p class="text-sm text-slate-500">No published modules yet.</p> }
      </div>
    </div>
  </div>
  <aside class="space-y-5">
    <div class="detail-card rounded-2xl border shadow-sm p-5">
      @if (isAdmin)
      {
        <p class="text-sm text-slate-500 mb-3">Read-only course preview for administration.</p>
        <a asp-controller="Admin" asp-action="Courses" class="w-full inline-flex items-center justify-center px-4 py-2 rounded-xl border border-indigo-200 text-indigo-700 text-sm font-semibold">Back to Manage Courses</a>
      }
      else if (canTeachCourse)
      {
        <a asp-controller="Content" asp-action="Manage" asp-route-courseId="@course.Id" class="w-full inline-flex items-center justify-center px-4 py-2 rounded-xl bg-indigo-600 text-white font-semibold text-sm hover:bg-indigo-700">Manage Course</a>
        <a asp-action="Students" asp-route-id="@course.Id" class="mt-3 w-full inline-flex items-center justify-center px-4 py-2 rounded-xl border border-indigo-200 text-indigo-700 text-sm font-semibold">View Students</a>
        @if (course.AllowDiscussions) { <a asp-action="Discussion" asp-route-id="@course.Id" class="mt-3 w-full inline-flex items-center justify-center px-4 py-2 rounded-xl border border-indigo-200 text-indigo-700 text-sm font-semibold">Open Discussion Zone</a> }
      }
      else if (enrolled)
      {
        <a asp-action="Content" asp-route-id="@course.Id" class="w-full inline-flex items-center justify-center px-4 py-2 rounded-xl bg-indigo-600 text-white font-semibold text-sm hover:bg-indigo-700">Continue Learning</a>
        @if (course.IsEnded) { <a asp-action="Certificate" asp-route-id="@course.Id" class="mt-3 w-full inline-flex items-center justify-center px-4 py-2 rounded-xl border border-emerald-300 text-emerald-700 text-sm font-semibold hover:bg-emerald-50"><i class="ri-award-line mr-1"></i> Download Certificate</a> }
        @if (course.AllowDiscussions) { <a asp-action="Discussion" asp-route-id="@course.Id" class="mt-3 w-full inline-flex items-center justify-center px-4 py-2 rounded-xl border border-indigo-200 text-indigo-700 text-sm font-semibold">Open Discussion Zone</a> }
        <form asp-controller="Enrollment" asp-action="Drop" method="post" class="mt-3"><input type="hidden" name="courseId" value="@course.Id" /><button class="w-full px-4 py-2 rounded-xl border border-red-200 text-red-600 text-sm font-semibold">Drop Course</button></form>
      }
      else if (pending)
      {
        <button disabled class="w-full px-4 py-2 rounded-xl bg-amber-100 text-amber-700 text-sm font-semibold">Enrollment Pending Approval</button>
        <form asp-controller="Enrollment" asp-action="Drop" method="post" class="mt-3"><input type="hidden" name="courseId" value="@course.Id" /><button class="w-full px-4 py-2 rounded-xl border border-slate-200 text-slate-700 text-sm font-semibold">Cancel Request</button></form>
      }
      else if (course.IsEnded || Model.IsAtCapacity)
      {
        <button disabled class="w-full px-4 py-2 rounded-xl bg-slate-200 text-slate-600 text-sm font-semibold">@(course.IsEnded ? "Course Ended" : "Course Full")</button>
      }
      else
      {
        <form asp-controller="Enrollment" asp-action="Enroll" method="post"><input type="hidden" name="courseId" value="@course.Id" /><button class="w-full px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold">@(course.EnrollmentType == "Approval" ? "Request Enrollment" : "Enroll Now")</button></form>
      }
      @if (canTeachCourse || enrolled)
      {
        <div class="mt-4 grid grid-cols-3 gap-2">
          <a asp-controller="Assignment" asp-action="Index" asp-route-courseId="@course.Id" class="text-center text-xs text-slate-600 border border-slate-200 rounded-lg px-2 py-2">Assignments</a>
          <a asp-controller="Quiz" asp-action="Index" asp-route-courseId="@course.Id" class="text-center text-xs text-slate-600 border border-slate-200 rounded-lg px-2 py-2">Quizzes</a>
          <a asp-controller="Announcement" asp-action="Index" asp-route-courseId="@course.Id" class="text-center text-xs text-slate-600 border border-slate-200 rounded-lg px-2 py-2">Updates</a>
        </div>
      }
    </div>
    @if (Model.IsStudent && enrolled)
    {
      <div class="detail-card rounded-2xl border shadow-sm p-5">
        <h3 class="font-semibold text-slate-800 mb-3">Rate Course &amp; Instructor</h3>
        <form asp-action="SubmitReview" asp-route-id="@course.Id" method="post" class="space-y-3">
          <div class="grid sm:grid-cols-2 gap-3">
            <div><label class="block text-xs text-slate-500 mb-1">Course rating</label><select name="courseRating" required class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm"><option value="">Select stars</option>@for (var rating = 1; rating <= 5; rating++) { if (Model.MyReview?.CourseRating == rating) { <option value="@rating" selected>@rating star@(rating == 1 ? "" : "s")</option> } else { <option value="@rating">@rating star@(rating == 1 ? "" : "s")</option> } }</select></div>
            <div><label class="block text-xs text-slate-500 mb-1">Instructor rating</label><select name="instructorRating" required class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm"><option value="">Select stars</option>@for (var rating = 1; rating <= 5; rating++) { if (Model.MyReview?.InstructorRating == rating) { <option value="@rating" selected>@rating star@(rating == 1 ? "" : "s")</option> } else { <option value="@rating">@rating star@(rating == 1 ? "" : "s")</option> } }</select></div>
          </div>
          <textarea name="comment" rows="3" class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm" placeholder="Share your learning experience...">@Model.MyReview?.Comment</textarea>
          <button class="w-full px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold">@(Model.MyReview == null ? "Submit Review" : "Update Review")</button>
        </form>
      </div>
    }
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
      <h3 class="font-semibold text-slate-800 mb-3">Related Courses</h3>
      @foreach (var related in Model.RelatedCourses) { <a asp-action="Details" asp-route-id="@related.Id" class="detail-link block border border-indigo-100 rounded-xl px-3 py-2 text-sm text-slate-700 mb-2">@related.Title</a> }
      @if (!Model.RelatedCourses.Any()) { <p class="text-sm text-slate-500">No related courses available.</p> }
    </div>
  </aside>
</div>
<div class="max-w-7xl mx-auto mt-6 detail-card rounded-2xl border shadow-sm p-5">
  <h3 class="font-semibold text-slate-800 mb-3">Recent Student Reviews</h3>
  @foreach (var review in Model.RecentReviews) { <div class="border border-slate-100 rounded-xl p-3 mb-3"><p class="text-sm font-semibold text-slate-700">@review.Student?.FullName</p><p class="text-xs text-slate-500 mt-1">Course: @review.CourseRating/5 &middot; Instructor: @review.InstructorRating/5 &middot; @review.UpdatedAt.ToString("MMM dd, yyyy")</p>@if (!string.IsNullOrWhiteSpace(review.Comment)) { <p class="text-sm text-slate-600 mt-2">@review.Comment</p> }</div> }
  @if (!Model.RecentReviews.Any()) { <p class="text-sm text-slate-500">No reviews yet for this course.</p> }
</div>
