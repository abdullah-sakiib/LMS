@model LMS.ViewModels.InstructorStudentProgressVM
@{
    ViewData["Title"] = "Student Progress";
    ViewData["PageTitle"] = "Student Progress";
    ViewData["PageSubtitle"] = Model.CourseTitle;
}

<div class="max-w-6xl mx-auto space-y-6">
    <div class="flex items-center justify-between gap-3">
        <div>
            <h2 class="text-xl font-bold text-slate-800">@Model.StudentName</h2>
            <p class="text-sm text-slate-500">@Model.StudentEmail</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Students" asp-route-id="@Model.CourseId" class="text-sm text-slate-600 hover:text-indigo-600">Back to students</a>
            <a asp-action="Details" asp-route-id="@Model.CourseId" class="text-sm text-indigo-600 hover:text-indigo-700">Course details</a>
        </div>
    </div>

    <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4">
            <p class="text-xs text-slate-500">Progress</p>
            <p class="text-2xl font-bold text-slate-800 mt-1">@Model.Percent.ToString("0.#")%</p>
            <p class="text-xs text-slate-400 mt-1">@Model.Completed / @Model.Total items completed</p>
            <div class="mt-3 w-full bg-slate-100 rounded-full h-2.5">
                <div class="bg-indigo-600 h-2.5 rounded-full" style="width:@Model.Percent%"></div>
            </div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4">
            <p class="text-xs text-slate-500">Course</p>
            <p class="text-lg font-semibold text-slate-800 mt-1">@Model.CourseTitle</p>
            <p class="text-xs text-slate-400 mt-1">Resources: @Model.Total</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4">
            <p class="text-xs text-slate-500">Completion</p>
            <p class="text-lg font-semibold text-slate-800 mt-1">@(Model.Percent >= 100 ? "Completed" : "In progress")</p>
            <p class="text-xs text-slate-400 mt-1">Last updated: @(Model.Resources.Where(item => item.CompletedAt.HasValue).OrderByDescending(item => item.CompletedAt).FirstOrDefault()?.CompletedAt?.ToString("MMM dd, yyyy") ?? "-")</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
            <h3 class="font-semibold text-slate-800">Resource Progress</h3>
            <p class="text-xs text-slate-400">@Model.Resources.Count items</p>
        </div>
        <div class="divide-y divide-slate-100">
            @foreach (var item in Model.Resources)
            {
                <div class="px-5 py-4 flex items-center justify-between gap-4">
                    <div>
                        <p class="text-sm font-semibold text-slate-800">@item.Title</p>
                        <p class="text-xs text-slate-400">@item.ModuleTitle · @item.Type</p>
                    </div>
                    <div class="text-right">
                        <p class="text-sm font-semibold @(item.IsCompleted ? "text-emerald-600" : "text-slate-500")">@(item.IsCompleted ? "Completed" : "Not completed")</p>
                        <p class="text-xs text-slate-400">@(item.CompletedAt?.ToString("MMM dd, yyyy") ?? "-")</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
