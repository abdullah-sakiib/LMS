@model LMS.ViewModels.InstructorCourseStudentsVM
@{
    ViewData["Title"] = $"{Model.CourseTitle} Students";
    ViewData["PageTitle"] = "Course Students";
    ViewData["PageSubtitle"] = Model.CourseTitle;
}

<div class="max-w-6xl mx-auto space-y-5">
    <div class="flex items-center justify-between gap-3">
        <div>
            <h2 class="text-xl font-bold text-slate-800">Enrolled Students</h2>
            <p class="text-sm text-slate-500">Approved enrollments and completion progress.</p>
        </div>
        <a asp-action="Details" asp-route-id="@Model.CourseId" class="text-sm text-indigo-600 hover:text-indigo-700">Back to course</a>
    </div>

    @if (!Model.Students.Any())
    {
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8 text-center text-slate-500">
            No approved enrollments yet.
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
            <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
                <p class="text-sm text-slate-600">@Model.Students.Count students</p>
                <p class="text-xs text-slate-400">@Model.TotalResources resources</p>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-50 text-slate-500">
                        <tr>
                            <th class="text-left px-5 py-3 font-semibold">Student</th>
                            <th class="text-left px-5 py-3 font-semibold">Progress</th>
                            <th class="text-left px-5 py-3 font-semibold">Enrolled</th>
                            <th class="text-right px-5 py-3 font-semibold">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model.Students)
                        {
                            <tr class="border-t border-slate-100 hover:bg-indigo-50/40">
                                <td class="px-5 py-3">
                                    <p class="font-semibold text-slate-800">@student.Name</p>
                                    <p class="text-xs text-slate-500">@student.Email</p>
                                </td>
                                <td class="px-5 py-3">
                                    <p class="text-xs text-slate-500">@student.Completed / @student.Total items</p>
                                    <div class="mt-2 w-40 bg-slate-100 rounded-full h-2">
                                        <div class="bg-indigo-600 h-2 rounded-full" style="width:@student.Percent%"></div>
                                    </div>
                                    <p class="text-xs text-slate-500 mt-1">@student.Percent.ToString("0.#")%</p>
                                </td>
                                <td class="px-5 py-3 text-slate-600">
                                    <p>@student.EnrolledAt.ToString("MMM dd, yyyy")</p>
                                    <p class="text-xs text-slate-400">Approved: @(student.ApprovedAt?.ToString("MMM dd, yyyy") ?? "-")</p>
                                </td>
                                <td class="px-5 py-3 text-right">
                                    <a asp-action="StudentProgress" asp-route-id="@Model.CourseId" asp-route-studentId="@student.StudentId" class="text-xs font-semibold text-indigo-600">View progress</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
