@model LMS.ViewModels.CourseVM
@{
    ViewData["Title"] = "Create Course";
    ViewData["PageTitle"] = "Create New Course";
    ViewData["PageSubtitle"] = "Fill in the details to publish your course";
}
<style>
  .input-field:focus { outline:none; border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.10); }
  .btn-primary { background:linear-gradient(135deg,#4f46e5,#6366f1); box-shadow:0 4px 14px rgba(99,102,241,.3); transition:all .25s; }
  .btn-primary:hover { transform:translateY(-1px); box-shadow:0 8px 20px rgba(99,102,241,.4); }
</style>
<div class="max-w-5xl mx-auto">
  <div class="flex items-center gap-2 text-xs text-slate-400 mb-6">
    <a asp-controller="Dashboard" asp-action="Index" class="hover:text-primary-600">Dashboard</a><i class="ri-arrow-right-s-line"></i><span class="text-slate-600 font-medium">Create Course</span>
  </div>
  <div class="flex items-center gap-0 mb-8">
    <div class="flex items-center flex-1"><div class="flex flex-col items-center"><div class="w-9 h-9 rounded-full flex items-center justify-center bg-primary-600 text-white"><i class="ri-information-line"></i></div><span class="text-xs font-medium mt-1.5 text-primary-600">Basic Info</span></div><div class="flex-1 h-0.5 bg-slate-200 mx-3 mt-[-18px]"></div></div>
    <div class="flex items-center flex-1"><div class="flex flex-col items-center"><div class="w-9 h-9 rounded-full flex items-center justify-center border-2 border-slate-200 text-slate-400"><i class="ri-settings-3-line"></i></div><span class="text-xs font-medium mt-1.5 text-slate-400">Settings</span></div><div class="flex-1 h-0.5 bg-slate-200 mx-3 mt-[-18px]"></div></div>
    <div class="flex flex-col items-center"><div class="w-9 h-9 rounded-full flex items-center justify-center border-2 border-slate-200 text-slate-400"><i class="ri-check-line"></i></div><span class="text-xs font-medium mt-1.5 text-slate-400">Ready</span></div>
  </div>
  <form asp-action="Create" method="post" class="grid lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-5">
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <h2 class="font-semibold text-slate-800 mb-5 flex items-center gap-2"><span class="w-6 h-6 bg-primary-100 text-primary-600 rounded-lg flex items-center justify-center text-xs font-bold">1</span> Basic Information</h2>
        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>
        <div class="mb-4"><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Course Title <span class="text-red-400">*</span></label><input asp-for="Title" id="course-title" oninput="updatePreview()" placeholder="e.g. Introduction to Algorithms" class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"/><span asp-validation-for="Title" class="text-xs text-red-500"></span></div>
        <div class="mb-4"><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Short Description</label><input asp-for="ShortDescription" id="course-description" oninput="updatePreview()" maxlength="280" placeholder="Short catalog summary..." class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"/></div>
        <div class="mb-4"><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Description <span class="text-red-400">*</span></label><textarea asp-for="Description" rows="5" placeholder="Describe what students will learn and why this course is valuable..." class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm resize-none"></textarea><span asp-validation-for="Description" class="text-xs text-red-500"></span></div>
        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <div><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Category</label><input asp-for="Category" placeholder="Computer Science" class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"/></div>
          <div><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Tags</label><input asp-for="Tags" placeholder="algorithms, python, data" class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"/></div>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Level</label><select asp-for="Level" class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"><option>Beginner</option><option>Intermediate</option><option>Advanced</option></select></div>
          <div><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Duration (weeks)</label><input asp-for="DurationWeeks" type="number" min="1" class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"/></div>
          <div><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Max Capacity</label><input asp-for="Capacity" type="number" min="1" class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"/></div>
          <div><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Initial Status</label><select asp-for="Status" class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"><option value="Draft">Save as draft</option><option value="Published">Publish now</option></select></div>
          <div><label class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Enrollment Type</label><select asp-for="EnrollmentType" class="input-field w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm"><option value="Open">Open enrollment</option><option value="Approval">Approval required</option></select></div>
          <label class="flex items-center gap-2 text-sm text-slate-600 pt-7"><input asp-for="AllowDiscussions" class="rounded border-slate-300"/> Allow student discussions</label>
        </div>
      </div>
      <div class="flex justify-between">
        <a asp-action="Index" class="inline-flex items-center gap-2 text-sm font-medium text-slate-600 border border-slate-200 rounded-xl px-5 py-3 hover:bg-slate-50"><i class="ri-arrow-left-line"></i> Cancel</a>
        <button type="submit" class="btn-primary inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-xl text-sm">Create Course <i class="ri-arrow-right-line"></i></button>
      </div>
    </div>
    <aside class="space-y-4">
      <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 sticky top-4">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-3">Live Preview</p>
        <div class="h-28 bg-gradient-to-br from-indigo-500 to-indigo-700 rounded-xl flex items-center justify-center mb-4"><i class="ri-book-open-line text-white/70 text-4xl"></i></div>
        <h3 id="preview-title" class="font-semibold text-slate-800">Your course title</h3>
        <p id="preview-desc" class="text-xs text-slate-500 mt-2 line-clamp-3">Your course description will appear here.</p>
        <div class="mt-4 text-xs text-slate-500 flex gap-2"><span class="bg-primary-50 text-primary-600 px-2 py-1 rounded-full">Instructor course</span><span class="bg-slate-50 px-2 py-1 rounded-full">Up to @Model.Capacity students</span></div>
      </div>
    </aside>
  </form>
</div>
@section Scripts {
<script>
  function updatePreview() {
    const title = document.getElementById('course-title').value.trim();
    const description = document.getElementById('course-description').value.trim();
    document.getElementById('preview-title').textContent = title || 'Your course title';
    document.getElementById('preview-desc').textContent = description || 'Your course description will appear here.';
  }
</script>
}
