@model LMS.ViewModels.CourseVM
@{
    ViewData["Title"] = "Edit Course";
}

<div class="max-w-3xl mx-auto bg-white rounded-2xl border border-slate-100 shadow-sm p-8">
    <h2 class="text-xl font-bold text-gray-800 mb-6">Edit Course</h2>

    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
            <input asp-for="Title"
                   class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
        </div>

        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Short Description</label>
            <input asp-for="ShortDescription" maxlength="280" class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
        </div>

        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            <textarea asp-for="Description" rows="4"
                      class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400"></textarea>
            <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
        </div>

        <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Category</label><input asp-for="Category" class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm" /></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Tags</label><input asp-for="Tags" class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm" /></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Level</label><select asp-for="Level" class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm"><option>Beginner</option><option>Intermediate</option><option>Advanced</option></select></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Duration (weeks)</label><input asp-for="DurationWeeks" type="number" min="1" class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm" /></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Capacity</label><input asp-for="Capacity" type="number" min="1" class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm" /></div>
            <div><label class="block text-sm font-medium text-gray-700 mb-1">Enrollment Type</label><select asp-for="EnrollmentType" class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm"><option value="Open">Open enrollment</option><option value="Approval">Approval required</option></select></div>
        </div>
        <label class="mb-4 flex items-center gap-2 text-sm text-gray-700"><input asp-for="AllowDiscussions" /> Allow student discussions</label>

        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select asp-for="Status"
                    class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400">
                <option value="Draft">Draft</option>
                <option value="Published">Published</option>
                <option value="Archived">Archived</option>
            </select>
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-2 rounded-lg transition">
                Save Changes
            </button>
            <a asp-action="Index"
                   class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-6 py-2 rounded-lg transition">
                Cancel
            </a>
        </div>
    </form>
</div>
