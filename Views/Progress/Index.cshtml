@model LMS.ViewModels.StudentProgressVM
@{
    ViewData["Title"] = "My Progress";
    var selectedCourse = Model.Courses.FirstOrDefault(item => item.CourseId == Model.SelectedCourseId);
}

<div class="max-w-5xl mx-auto space-y-5">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h2 class="text-xl font-bold text-slate-800">My Progress</h2>
            <p class="text-sm text-slate-500">Track course completion and assessment performance.</p>
        </div>
        @if (Model.Courses.Any())
        {
            <div class="flex items-center gap-2">
                <label for="course-filter" class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Course</label>
                <select id="course-filter" class="px-3 py-2 rounded-xl border border-slate-200 bg-white text-sm" onchange="switchCourse(this.value)">
                    @foreach (var course in Model.Courses)
                    {
                        <option value="@course.CourseId" selected="@(course.CourseId == Model.SelectedCourseId)">@course.Title</option>
                    }
                </select>
            </div>
        }
    </div>

    @if (!Model.Courses.Any())
    {
        <div class="bg-white rounded-2xl shadow-sm p-8 text-center text-slate-400">
            You are not enrolled in any courses yet.
        </div>
    }
    else
    {
        <div class="grid lg:grid-cols-3 gap-4">
            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4">
                <p class="text-xs text-slate-500">Overall Progress</p>
                <p class="text-2xl font-bold text-slate-800 mt-1">@selectedCourse?.Percent.ToString("0.#")%</p>
                <p class="text-xs text-slate-400 mt-1">@selectedCourse?.Completed / @selectedCourse?.Total items completed</p>
                <div class="mt-3 w-full bg-slate-100 rounded-full h-2.5">
                    <div class="bg-indigo-600 h-2.5 rounded-full transition-all" style="width:@(selectedCourse?.Percent ?? 0)%"></div>
                </div>
            </div>
            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4">
                <p class="text-xs text-slate-500">Assignments</p>
                <p class="text-2xl font-bold text-slate-800 mt-1">@selectedCourse?.GradedAssignments</p>
                <p class="text-xs text-slate-400">Graded / @selectedCourse?.AssignmentCount total</p>
                <div class="mt-3 flex items-center gap-3">
                    <div class="w-12 h-12 rounded-full" style="background:conic-gradient(#4f46e5 @(selectedCourse?.AssignmentAverage ?? 0)%, #e2e8f0 0)"></div>
                    <div>
                        <p class="text-xs text-slate-500">Average</p>
                        <p class="text-lg font-semibold text-slate-800">@selectedCourse?.AssignmentAverage.ToString("0.#")%</p>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4">
                <p class="text-xs text-slate-500">Quizzes</p>
                <p class="text-2xl font-bold text-slate-800 mt-1">@selectedCourse?.QuizAttempts</p>
                <p class="text-xs text-slate-400">Attempts / @selectedCourse?.QuizCount total</p>
                <div class="mt-3 flex items-center gap-3">
                    <div class="w-12 h-12 rounded-full" style="background:conic-gradient(#0ea5e9 @(selectedCourse?.QuizAverage ?? 0)%, #e2e8f0 0)"></div>
                    <div>
                        <p class="text-xs text-slate-500">Average</p>
                        <p class="text-lg font-semibold text-slate-800">@selectedCourse?.QuizAverage.ToString("0.#")%</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-3">
            @foreach (var item in Model.Courses)
            {
                <div class="course-progress-card bg-white rounded-2xl shadow-sm p-5" data-course-id="@item.CourseId">
                    <div class="flex items-center justify-between mb-2">
                        <div>
                            <h3 class="font-semibold text-slate-800">@item.Title</h3>
                            <p class="text-xs text-slate-400">@item.Completed / @item.Total items completed</p>
                        </div>
                        <span class="text-lg font-bold @(item.Percent >= 100 ? "text-emerald-500" : "text-indigo-600")">
                            @item.Percent%
                        </span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-2.5">
                        <div class="bg-indigo-600 h-2.5 rounded-full transition-all" style="width:@item.Percent%"></div>
                    </div>
                    @if (item.Percent >= 100)
                    {
                        <p class="text-xs text-emerald-500 mt-2">Course completed!</p>
                    }
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
  function switchCourse(courseId) {
    const cards = document.querySelectorAll('.course-progress-card');
    cards.forEach(card => {
      card.classList.toggle('hidden', card.dataset.courseId !== courseId);
    });
  }
  if (document.getElementById('course-filter')) {
    switchCourse(document.getElementById('course-filter').value);
  }
</script>
}