@model LMS.ViewModels.AssignmentWorkspaceVM
@{
    ViewData["Title"] = "Assignments";
    ViewData["PageTitle"] = "Assignments";
    ViewData["PageSubtitle"] = "Track and submit assignment work";
}
<div class="max-w-6xl mx-auto space-y-5">
  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 flex flex-wrap items-center justify-between gap-3">
    <div><h2 class="text-lg font-bold text-slate-800">Assignments</h2><p class="text-sm text-slate-500 mt-1">@(Model.IsStudent ? "Submit pending work for your enrolled courses." : "View assignment list for your courses.")</p></div>
  </div>
  <div class="grid lg:grid-cols-2 gap-4">
    @foreach (var row in Model.Rows)
    {
      var assignment = row.Assignment;
      var submission = row.Submission;
      var status = submission?.Status ?? "Pending";
      var badge = status == "Graded" ? "text-emerald-700 bg-emerald-50 border-emerald-100" : status == "Late" ? "text-red-600 bg-red-50 border-red-100" : status == "Submitted" ? "text-amber-600 bg-amber-50 border-amber-100" : "text-slate-600 bg-slate-100 border-slate-100";
      <article class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
        <div class="flex items-start justify-between gap-3">
          <div><h3 class="font-semibold text-slate-800">@assignment.Title</h3><p class="text-xs text-slate-500 mt-1">@assignment.Course?.Title</p></div>
          <span class="text-xs font-semibold @badge border px-2 py-1 rounded-full">@status</span>
        </div>
        <div class="mt-3 text-sm text-slate-600 space-y-1">
          <p>Max score: @assignment.MaxScore</p>
          <p>Due: @assignment.Deadline.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
          @if (!string.IsNullOrWhiteSpace(assignment.AttachmentPath)) { <p>Attachment: <a href="@assignment.AttachmentPath" target="_blank" rel="noopener" class="text-indigo-600 hover:text-indigo-700">View file</a></p> }
          @if (submission != null) { <p>Latest file: <a href="@submission.FilePath" target="_blank" rel="noopener" class="text-indigo-600 hover:text-indigo-700">View upload</a></p> }
          @if (submission?.Grade != null) { <p>Score: @submission.Grade.Value.ToString("0.##")/@assignment.MaxScore</p> }
        </div>
        @if (Model.IsStudent)
        {
          <form asp-action="Submit" method="post" enctype="multipart/form-data" class="mt-4 space-y-3">
            <input type="hidden" name="assignmentId" value="@assignment.Id" /><input type="hidden" name="returnToWorkspace" value="true" />
            <input type="file" name="file" required class="w-full text-sm border border-slate-200 rounded-xl px-3 py-2" />
            <textarea name="comment" rows="2" placeholder="Optional note to your instructor" class="w-full text-sm border border-slate-200 rounded-xl px-3 py-2">@submission?.Comment</textarea>
            <button type="submit" class="w-full text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 transition py-2.5 rounded-xl">@(submission == null ? "Submit" : "Resubmit")</button>
          </form>
        }
        else
        {
          <div class="mt-4 flex gap-2"><a asp-action="Details" asp-route-id="@assignment.Id" class="text-sm font-semibold text-indigo-600 border border-indigo-200 px-3 py-2 rounded-xl">View Submissions</a><a asp-action="Edit" asp-route-id="@assignment.Id" class="text-sm font-semibold text-slate-600 border border-slate-200 px-3 py-2 rounded-xl">Edit</a></div>
        }
      </article>
    }
    @if (!Model.Rows.Any()) { <div class="lg:col-span-2 bg-white rounded-2xl border border-slate-100 shadow-sm p-8 text-center"><p class="text-slate-700 font-semibold">No assignments found</p><p class="text-sm text-slate-400 mt-1">Assignments will appear here when available.</p></div> }
  </div>
</div>
