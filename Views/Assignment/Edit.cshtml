@model LMS.ViewModels.AssignmentVM
@{
    ViewData["Title"] = "Edit Assignment";
}

<div class="max-w-xl mx-auto bg-white rounded-2xl shadow-sm p-6">
    <h2 class="text-xl font-bold text-gray-800 mb-5">Edit Assignment</h2>
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CourseId" />
        <div class="space-y-4">
            <div>
                <label class="text-sm font-medium text-gray-700">Title</label>
                <input asp-for="Title" class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
            <div>
                <label class="text-sm font-medium text-gray-700">Description</label>
                <textarea asp-for="Description" rows="4" class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400"></textarea>
            </div>
            <div>
                <label class="text-sm font-medium text-gray-700">Deadline</label>
                <input asp-for="Deadline" type="datetime-local" class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
            </div>
            <div>
                <label class="text-sm font-medium text-gray-700">Max Score</label>
                <input asp-for="MaxScore" type="number" min="1" class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm" />
            </div>
            <div>
                <label class="text-sm font-medium text-gray-700">Replace Attachment</label>
                <input type="file" name="attachment" class="mt-1 w-full border border-gray-200 rounded-lg px-3 py-2 text-sm" />
            </div>
        </div>
        <button type="submit" class="mt-5 w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2 rounded-lg text-sm transition">
            Save Changes
        </button>
    </form>
</div>
